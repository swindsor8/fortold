# ── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=fortold
POSTGRES_PASSWORD=fortold_dev
POSTGRES_DB=fortold_db
DATABASE_URL=postgresql+asyncpg://fortold:fortold_dev@postgres:5432/fortold_db

# For local dev without Docker (point to localhost):
# DATABASE_URL=postgresql+asyncpg://fortold:fortold_dev@localhost:5432/fortold_db

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379
# Local: REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_generate_with_openssl_rand_hex_32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── Claude API ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
LLM_MODEL=claude-sonnet-4-6
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOKENS=4096

# ── Storage ──────────────────────────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
ARTIFACTS_DIR=/app/artifacts
MAX_UPLOAD_BYTES=104857600

# ── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# ── RQ ───────────────────────────────────────────────────────────────────────
RQ_QUEUE_NAME=fortold_queue

# ── Frontend (copy to frontend/.env.local) ───────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
